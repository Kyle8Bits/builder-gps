# Copy to builder-gps/.env and fill in.
# Single root .env — both the backend (FastAPI) and frontend (Next.js)
# read from here.

# === Backend (apps/api) ===
# Required for Phase 03+ (LLM calls).
# Get a free Groq key in 1 min: https://console.groq.com/keys
# Real Groq keys start with "gsk_..." (56 chars).
GROQ_API_KEY=gsk_your-key-here

# Optional backend overrides
# CORS_ORIGINS=["http://localhost:3000"]
# SQLITE_PATH=builder_gps.db
# MODEL_DECOMPOSE=llama-3.3-70b-versatile
# MODEL_COMPUTE_PATH=llama-3.3-70b-versatile

# === Frontend (apps/web) ===
# Defaults to http://localhost:8000 if unset.
# NEXT_PUBLIC_API_URL=http://localhost:8000
