# Copy to apps/api/.env and fill in.
# Loaded by apps/api/app/config.py.

# === Required ===
# Get a free Groq key in 1 min: https://console.groq.com/keys
# Real keys start with "gsk_..." (56 chars).
GROQ_API_KEY=gsk_your-key-here

# === Optional ===
# Where the SQLite file lives (relative to wherever uvicorn is launched).
# SQLITE_PATH=builder_gps.db

# CORS allowlist — add your deployed web origin here in production.
# CORS_ORIGINS=["http://localhost:3000","https://builder-gps.vercel.app"]

# LLM model identifiers — swap to Claude/OpenAI/Gemini-flavored ids after
# you point apps/api/app/services/llm_client.py at a different provider.
# MODEL_DECOMPOSE=llama-3.3-70b-versatile
# MODEL_COMPUTE_PATH=llama-3.3-70b-versatile

# === Agentic stack (Phase 01+) ===
# v1 ships Groq-only — see plans/260617-1900-agentic-refactor-and-knowledge-layer/.
# To swap to Claude post-Devpost: set ANTHROPIC_API_KEY and flip AGENT_CLIENT_PROVIDER=anthropic.

# Voyage AI (Phase 02 — embeddings for session shortlist).
# Free tier 50M tokens/mo: https://dash.voyageai.com
VOYAGE_API_KEY=pa-your-key-here

# Tavily (Phase 03 — web search tool inside the decompose agent).
# Free tier (verify exact quota in dashboard): https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Anthropic (post-Devpost — leave blank for v1).
# https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Agent client provider — "groq" (v1) or "anthropic" (post-Devpost swap).
# AGENT_CLIENT_PROVIDER=groq

# Agentic loop knobs (override if you want tighter caps).
# DECOMPOSE_MAX_ITERATIONS=6
# DECOMPOSE_COVERAGE_THRESHOLD=0.8
# CRITIC_READINESS_THRESHOLD=0.75
# CRITIC_MAX_RETRIES=2
# TAVILY_TIMEOUT_SECONDS=8

# === Organizer admin import ===
# Shared bearer token for /admin endpoints. Organizers paste this on the
# /admin page to replace the mock workshop catalog with the live AABW
# schedule. Empty = admin disabled (endpoints return 503).
# Use a long random string (e.g. `openssl rand -hex 32`).
# ADMIN_TOKEN=

# === Per-person goal-change rate limit ===
# Caps how often one builder can re-run the full LLM pipeline.
# Defaults: 5 calls / 15 min. Applied to POST /builder/state and
# POST /path/regenerate. Marking sessions is normal use and NOT limited.
# Keyed by cookie-bound builder_id when present, else client IP.
# Set GOAL_CHANGE_MAX_CALLS=0 to disable entirely (post-win deployment).
# GOAL_CHANGE_MAX_CALLS=5
# GOAL_CHANGE_WINDOW_SECONDS=900
