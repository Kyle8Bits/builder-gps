# Reference only — these env vars are NOT loaded from a .env file.
# Set them in your AI client's MCP config block (Claude Desktop / Claude Code
# / Cursor / Windsurf) — see apps/mcp/README.md for snippets.
#
# Listed here so a single grep tells you what the server reads at runtime.

# === Required ===
# UUID of the builder whose path this MCP session reads/writes.
# Copy from the web app footer ("Connect via MCP" panel).
# Treat like a password — anyone with it can mark sessions as you.
BUILDER_GPS_BUILDER_ID=paste-uuid-here

# === Optional ===
# Backend API URL. Defaults to http://localhost:8000 if unset.
# Point at your deployed FastAPI for production use.
# BUILDER_GPS_API_URL=http://localhost:8000
