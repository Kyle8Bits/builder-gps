# Copy to apps/web/.env.local and fill in.
# Next.js auto-loads .env.local from this directory.
# All vars are optional — leave blank to hide the corresponding CTA.

# Backend URL (defaults to http://localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Devpost submission URL — renders "Vote on Devpost" CTAs in nav + closing section
# NEXT_PUBLIC_DEVPOST_URL=https://devpost.com/software/your-submission

# YouTube embed URL — renders the demo video on landing
# Use the /embed/ form, not the regular watch URL.
# NEXT_PUBLIC_DEMO_VIDEO_URL=https://www.youtube.com/embed/VIDEO_ID

# GitHub repo URL — renders the "GitHub ↗" link in landing footer
# NEXT_PUBLIC_GITHUB_URL=https://github.com/Kyle8Bits/builder-gps
